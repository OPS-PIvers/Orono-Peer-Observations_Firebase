rules_version = '2';

// =============================================================================
// Orono Peer Observations — Firestore Security Rules
// =============================================================================
// Multiple layers of defense protect against non-domain sign-ins:
//   1) GoogleAuthProvider's `hd` parameter (SignInScreen.tsx:36) restricts
//      the account chooser to @orono.k12.mn.us.
//   2) Client-side domain check in SignInScreen.signIn() verifies the signed-
//      in user's email after signInWithPopup() resolves; if it fails, the
//      Auth user is deleted and a clear error is shown.
//   3) AuthProvider enforces domain on onAuthStateChanged and onIdTokenChanged;
//      any non-domain user is signed out immediately.
//   4) These rules re-check the email domain on every Firestore request via
//      isFromOronoDomain() and constrain what each role can read/write based
//      on custom claims.
//
// Custom claims set by the auth flow:
//   request.auth.token.email                — verified email
//   request.auth.token.role                 — professional staff role slug (e.g. "administrator")
//   request.auth.token.hasSpecialAccess     — true for Admin / Peer Eval / Full Access
//   request.auth.token.isAdmin              — true for Administrator/Full Access roles or hasAdminAccess flag
//
// Per the migration plan: in v1 admins can edit everything that's currently
// sheet-editable plus a handful of code-locked items. Cloud Functions use
// the Admin SDK which bypasses these rules, so privileged server-side
// operations don't need explicit allows here.
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers -------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isFromOronoDomain() {
      return isSignedIn()
        && request.auth.token.email is string
        && request.auth.token.email.matches('.*@orono[.]k12[.]mn[.]us$');
    }

    function role() {
      return request.auth.token.role;
    }

    function hasSpecialAccess() {
      return isFromOronoDomain() && request.auth.token.hasSpecialAccess == true;
    }

    function isAdmin() {
      return isFromOronoDomain() && request.auth.token.isAdmin == true;
    }

    function isCurrentUserEmail(email) {
      return isFromOronoDomain() && request.auth.token.email == email;
    }

    // The requesting staff doc (lowercased-email key matches the token email).
    function staffDocData() {
      return get(/databases/$(database)/documents/staff/$(request.auth.token.email)).data;
    }

    // Does the requester satisfy the given module's autoEnable rule? Mirrors
    // staffMatchesAutoEnable in @ops/shared — keep the two in sync.
    function matchesModuleAutoEnable(moduleId) {
      let auto = get(/databases/$(database)/documents/modules/$(moduleId)).data.get('autoEnable', null);
      let y = staffDocData().get('year', 1);
      let summ = staffDocData().get('summativeYear', false);
      let status = y >= 4 ? 'probationary' : (summ ? 'high' : 'low');
      let dy = y >= 4 ? y - 3 : y;
      return auto != null
        && ((auto.dimension == 'status' && auto.value == status)
            || (auto.dimension == 'year' && auto.value == dy));
    }

    function unchanged(field) {
      // Use .get(field, null) so this works even when the field is absent
      // on either side of the update (e.g., finalizedAt on a Draft).
      return resource.data.get(field, null) == request.resource.data.get(field, null);
    }

    function isCreating() {
      return resource == null;
    }

    // --- Default deny --------------------------------------------------------
    // Anything not explicitly granted below is denied. Always.
    match /{document=**} {
      allow read, write: if false;
    }

    // --- /staff/{email} ------------------------------------------------------
    // Own doc: read only. Admins: full read/write. Special-access (PE): read
    // all (needed for the filter UI to list potential observees). Any domain
    // user may list ONLY active administrators (the Profile "My
    // Administrators" card) — the query must filter on
    // role == 'administrator' AND isActive == true or Firestore can't prove
    // the resource.data conditions and rejects the whole list.
    match /staff/{email} {
      allow get: if isCurrentUserEmail(email) || hasSpecialAccess();
      allow list: if hasSpecialAccess()
        || (isFromOronoDomain()
            && resource.data.role == 'administrator'
            && resource.data.isActive == true);
      allow create, update, delete: if isAdmin();

      // Per-staff module completion. Only the owner (or admin) reads/writes.
      match /moduleProgress/{itemId} {
        allow read, write: if isCurrentUserEmail(email) || isAdmin();
      }
    }

    // --- /roles, /rubrics ----------------------------------------------------
    // Read: anyone signed-in from the domain (the client UI needs these to
    // render the rubric for any user). Write: admin only.
    match /roles/{roleId} {
      allow read: if isFromOronoDomain();
      allow write: if isAdmin();
    }

    match /buildings/{buildingId} {
      allow read: if isFromOronoDomain();
      allow write: if isAdmin();
    }

    // --- /modules/{moduleId} -------------------------------------------------
    // Admin-defined participation tracks. Read: anyone signed-in from the
    // domain (clients render module chips + nav). Write: admin only.
    match /modules/{moduleId} {
      allow read: if isFromOronoDomain();
      allow write: if isAdmin();
    }

    // --- module items (collection-group rule) --------------------------------
    // Resource/material content under /modules/{id}/items. Read: admin, OR a
    // signed-in staff member whose /staff doc lists this item's moduleId in
    // its `modules` array. Recursive ({path=**}) so the same rule authorizes
    // both direct gets and the dashboard's collectionGroup('items') query.
    // Write: admin only.
    //
    // Scope note: the only `items` subcollection today is /modules/{id}/items;
    // {path=**} is required for collection-group support. Any future `items`
    // subcollection elsewhere would also match this rule — keep that in mind.
    // Casing note: staff doc IDs are lowercased emails. This get() keys off
    // request.auth.token.email, which Google Workspace returns lowercase; if a
    // token ever carried a mixed-case email the get() would 404 and access
    // would be (safely) denied via the .get('modules', []) default.
    match /{path=**}/items/{itemId} {
      allow read: if isAdmin()
        || (isFromOronoDomain()
            && (resource.data.moduleId in staffDocData().get('modules', [])
                || matchesModuleAutoEnable(resource.data.moduleId)));
      allow write: if isAdmin();
    }

    // --- module section content (collection-group rule) ----------------------
    // Rich-text section bodies under /modules/{id}/content/{sectionId}. The
    // bodies are deliberately stored OUTSIDE the (domain-readable) module doc so
    // cohort-targeted guidance (probationary-only, summative-only, …) is gated
    // exactly like resource/material items: read for admins, OR a signed-in
    // staff member whose /staff doc lists this content's moduleId (or who
    // matches the module's autoEnable rule). Write: admin only.
    //
    // The module doc's `sections` array keeps only public layout metadata
    // (id/type/title) so chips + nav stay domain-readable. Doc id is the owning
    // section id, so each section has at most one content doc.
    //
    // Scope/casing notes mirror the items rule above ({path=**} for
    // collection-group support; lowercased staff doc ids).
    match /{path=**}/content/{sectionId} {
      allow read: if isAdmin()
        || (isFromOronoDomain()
            && (resource.data.moduleId in staffDocData().get('modules', [])
                || matchesModuleAutoEnable(resource.data.moduleId)));
      allow write: if isAdmin();
    }

    match /rubrics/{rubricId} {
      allow read: if isFromOronoDomain();
      allow write: if isAdmin();
    }

    // --- /roleYearMappings/{mappingId} ---------------------------------------
    // Doc id convention: `${roleId}_${year}` (e.g. "teacher_1").
    match /roleYearMappings/{mappingId} {
      allow read: if isFromOronoDomain();
      allow write: if isAdmin();
    }

    // --- /workProductQuestions ----------------------------------------------
    // Staff need to read questions (for WorkProductAnswerForm / InstructionalRoundAnswerForm).
    // Writes are admin-only.
    match /workProductQuestions/{id} {
      allow read: if isFromOronoDomain();
      allow write: if isAdmin();
    }

    // --- /emailTemplates -----------------------------------------------------
    // Admin-only — they're not user-facing.
    match /emailTemplates/{id} {
      allow read, write: if isAdmin();
    }

    // --- /observationWindows/{windowId} -------------------------------------
    // A scheduling window. Read: special-access (PE/admin) or an invited
    // staff member (their email is in invitedEmails). Create: special-access,
    // and the observer must be the caller.
    //
    // Update + delete: CLIENT writes are denied entirely. All mutations
    // (peBusyIntervals, dayCounts, invitees, status) flow through callable
    // Cloud Functions via the Admin SDK — this keeps the evaluator-time
    // ledger and per-day caps atomic and prevents clients from corrupting
    // those invariants. Admins may hard-delete a window document (e.g.
    // test-data cleanup), but that too goes through the callable in the UI.
    match /observationWindows/{windowId} {
      allow get, list: if hasSpecialAccess()
        || (isFromOronoDomain() && request.auth.token.email in resource.data.invitedEmails);
      allow create: if hasSpecialAccess()
        && request.resource.data.observerEmail == request.auth.token.email;
      allow update: if false;
      allow delete: if isAdmin();

      // Slots: readable by anyone who can read the parent window; never
      // client-writable (mutated only inside the booking transaction).
      match /slots/{slotId} {
        allow read: if hasSpecialAccess()
          || (isFromOronoDomain()
              && request.auth.token.email in
                 get(/databases/$(database)/documents/observationWindows/$(windowId)).data.invitedEmails);
        allow write: if false;
      }

      // Day-preference submissions: readable by the owner, the observer, or
      // an admin. Submitted via callable so day-cap accounting stays atomic.
      match /preferences/{prefEmail} {
        allow read: if hasSpecialAccess()
          || isCurrentUserEmail(prefEmail)
          || (isFromOronoDomain()
              && request.auth.token.email ==
                 get(/databases/$(database)/documents/observationWindows/$(windowId)).data.observerEmail);
        allow write: if false;
      }

      // Per-invitee invite tokens. Stored here so the window doc's invitees[]
      // array need not carry every token (which would expose all invitees'
      // tokens to every other invitee who can read the window doc). Doc id is
      // `${email}::${buildingId}` — the same key used by inviteeEntryKey().
      // Read: special-access (PE/admin) — needed to re-build booking links.
      //       Individual invitees do NOT need to read here; the token arrives
      //       via the invite email and is validated entirely server-side.
      // Write: denied to all clients; only the Admin SDK (Cloud Functions) may
      //        write here.
      match /tokens/{tokenKey} {
        allow read: if hasSpecialAccess();
        allow write: if false;
      }
    }

    // --- /buildingSchedules/{buildingId} ------------------------------------
    // Bell schedules drive the booking calendar. The booking UI needs to read
    // period names/times, so anyone signed-in from the domain may read.
    // Writes are admin-only (Admin Console → Building schedule editor).
    match /buildingSchedules/{buildingId} {
      allow read: if isFromOronoDomain();
      allow write: if isAdmin();
    }

    // --- /signupFields/{fieldId} --------------------------------------------
    // Admin-defined detail fields staff fill in when booking. Read for anyone
    // signed-in (the booking form renders them); write admin-only.
    match /signupFields/{fieldId} {
      allow read: if isFromOronoDomain();
      allow write: if isAdmin();
    }

    // --- /appSettings --------------------------------------------------------
    // Branding and a few public-ish flags need to be readable by everyone
    // signed in (for app name, logo, banner). Writes are admin-only.
    match /appSettings/{id} {
      allow read: if isFromOronoDomain();
      allow write: if isAdmin();
    }

    // --- /observations/{observationId} --------------------------------------
    //
    // Read:
    //   - observer (creator) of the observation
    //   - observed staff member, ONLY if status == 'Finalized'
    //   - any user with special access (admin / PE / full access)
    //
    // Create: special-access only (PEs and admins create observations).
    //
    // Update:
    //   - admin: any field
    //   - observer + currently Draft: any field except status (status moves
    //     to Finalized via a callable Cloud Function only). The lifecycle
    //     transition Draft → Finalized must happen server-side because it
    //     also needs to render PDF, share Drive folder, send email, etc.
    //
    // Delete: admin only.
    match /observations/{observationId} {
      allow get: if (
        isCurrentUserEmail(resource.data.observerEmail)
        || isCurrentUserEmail(resource.data.observedEmail)
        || hasSpecialAccess()
      );
      allow list: if hasSpecialAccess()
        || isCurrentUserEmail(resource.data.observedEmail);

      allow create: if hasSpecialAccess()
        && request.resource.data.observerEmail == request.auth.token.email
        && request.resource.data.status == 'Draft';

      allow update: if isAdmin()
        || (
          isCurrentUserEmail(resource.data.observerEmail)
          && resource.data.status == 'Draft'
          && unchanged('status')
          && unchanged('observerEmail')
          && unchanged('observedEmail')
          && unchanged('createdAt')
          && unchanged('finalizedAt')
          // Scheduling linkage is server-managed; an observer editing a Draft
          // can't rebind it to another window/slot.
          && unchanged('windowId')
          && unchanged('slotId')
          && unchanged('scheduledStartAt')
          && unchanged('scheduledEndAt')
          // Drive linkage + server-produced artifacts are server-managed
          // (callables/triggers write them via the Admin SDK). A spoofed
          // driveFolderId could point Draft-delete cleanup at the
          // district-wide parent folder; a spoofed pdfDriveFileId would
          // change where "View PDF" sends the observed staff member.
          && unchanged('driveFolderId')
          && unchanged('pdfDriveFileId')
          && unchanged('audioDriveFileIds')
          && unchanged('transcripts')
          && unchanged('evidenceLinks')
        )
        || (
          isCurrentUserEmail(resource.data.observedEmail)
          && resource.data.status == 'Draft'
          && resource.data.type in ['Work Product', 'Instructional Round']
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['workProductAnswers', 'lastModifiedAt'])
        )
        || (
          // Observed staff acknowledging their finalized observation — can
          // only touch the two ack fields plus the audit timestamp.
          isCurrentUserEmail(resource.data.observedEmail)
          && resource.data.status == 'Finalized'
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['acknowledgedAt', 'acknowledgedBy', 'lastModifiedAt'])
        );

      allow delete: if isAdmin()
        || (
          isCurrentUserEmail(resource.data.observerEmail)
          && resource.data.status == 'Draft'
        );
    }

    // --- /userCalendarTokens/{email} ----------------------------------------
    // Per-user Google Calendar OAuth credentials. Server-only — refresh
    // tokens never leave the backend. Cloud Functions use the Admin SDK
    // (which bypasses rules); clients are denied entirely.
    match /userCalendarTokens/{email} {
      allow read, write: if false;
    }

    // --- /auditLog -----------------------------------------------------------
    // Read: admin only. No client ever writes — Cloud Functions use admin SDK.
    match /auditLog/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // --- /rateLimitCounters --------------------------------------------------
    // Per-user fixed-window counters backing the saves/min, uploads/hr and
    // transcriptions/day limits. Maintained exclusively by Cloud Functions via
    // the Admin SDK (which bypasses rules); clients are denied entirely so a
    // client can never read its remaining budget or zero out its own counter.
    match /rateLimitCounters/{id} {
      allow read, write: if false;
    }

    // --- /transcriptionJobs --------------------------------------------------
    // Read: the requester and admins. Writes are server-only.
    match /transcriptionJobs/{id} {
      allow get: if isAdmin()
        || isCurrentUserEmail(resource.data.requestedBy);
      allow list: if isAdmin();
      allow write: if false;
    }

    // --- /mail ---------------------------------------------------------------
    // Trigger Email extension writes and reads via admin SDK — clients must
    // never write here directly (that would bypass template rendering and
    // audit logging).
    match /mail/{document} {
      allow read, write: if false;
    }

    // --- /dashboardQuickMaterials/{id} --------------------------------------
    // Single "global" doc holding the right-rail quick-materials list. Read
    // for everyone signed-in; write for admin only (Admin Console →
    // Dashboard surface).
    match /dashboardQuickMaterials/{id} {
      allow read: if isFromOronoDomain();
      allow write: if isAdmin();
    }

    // The dashboard feature config doc lives at /appSettings/dashboard and
    // is covered by the /appSettings rule above (everyone reads, admin
    // writes) — no separate match needed.
  }
}
