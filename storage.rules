rules_version = '2';

// Storage is intentionally minimal — primary blob storage is Google Drive
// (via service account + Domain-Wide Delegation). Any file we do put in
// Cloud Storage (e.g., temp uploads pre-Drive transfer, app branding logo
// fallbacks) goes under /admin-uploads/ and is admin-only.

service firebase.storage {
  match /b/{bucket}/o {
    match /admin-uploads/{path=**} {
      // Mirror the Firestore rules: admin = the isAdmin custom claim, not the
      // role slug. (The role slug may be e.g. "instructional-specialist" while
      // isAdmin is still true.) Branding logos are read publicly via their
      // tokenized download URL, so SDK read can stay auth-only.
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.isAdmin == true;
    }
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
