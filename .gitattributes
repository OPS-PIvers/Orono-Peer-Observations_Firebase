# Enforce LF line endings for all text files on every platform.
# This overrides core.autocrlf, so the working tree is LF even on Windows —
# keeping local Prettier/ESLint in agreement with CI (Linux, LF).
* text=auto eol=lf

# Binary assets: never apply line-ending or text-diff conversion.
# (None tracked today, but this protects assets added later. SVG is XML/text,
# so it is intentionally left as text for clean diffs.)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.otf   binary
*.pdf   binary
*.zip   binary
*.gz    binary
