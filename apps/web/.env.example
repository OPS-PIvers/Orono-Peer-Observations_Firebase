# Firebase web SDK config — fetch from Firebase console:
#   Project Settings → General → Your apps → SDK setup and configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=peer-evaluator-rubric.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=peer-evaluator-rubric
VITE_FIREBASE_STORAGE_BUCKET=peer-evaluator-rubric.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=968674433533
VITE_FIREBASE_APP_ID=

# Local dev: point all SDKs at the emulator suite. Set to "true" for local work,
# unset / "false" when smoke-testing against live Firebase from a deployed
# preview channel.
VITE_USE_EMULATORS=true

# Google Calendar OAuth — web client id from Cloud Console
#   (APIs & Services -> Credentials -> OAuth client -> Web application).
# Same value as the functions GOOGLE_OAUTH_CLIENT_ID param. Public, safe to ship.
VITE_GOOGLE_OAUTH_CLIENT_ID=
