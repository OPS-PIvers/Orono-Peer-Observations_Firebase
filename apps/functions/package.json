{
  "name": "@ops/functions",
  "version": "0.0.1",
  "private": true,
  "main": "lib/index.js",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "serve": "pnpm build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "firebase-admin": "^13.6.0",
    "firebase-functions": "^7.0.5",
    "google-auth-library": "^10.6.2",
    "googleapis": "^150.0.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@ops/shared": "workspace:*",
    "@types/node": "^22.10.10",
    "esbuild": "^0.28.1",
    "firebase-functions-test": "^3.4.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
