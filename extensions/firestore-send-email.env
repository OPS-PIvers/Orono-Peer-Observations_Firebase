# Trigger Email extension (firebase/firestore-send-email) — instance config.
# Exported from the live peer-evaluator-rubric project via `firebase ext:export`.
#
# Functions write docs to the /mail collection (see apps/functions/src/lib/emailUtils.ts);
# the extension picks them up, sends via SMTP, and writes delivery state back onto
# the doc (consumed by apps/functions/src/email/onMailDelivered.ts).
#
# SMTP_PASSWORD is NOT stored here — it lives in Secret Manager under the secret
# name `firestore-send-email-SMTP_PASSWORD`; the line below is the Secret Manager
# resource reference, not a credential.
#
# Deploying changes to this config is a deliberate manual step
# (`firebase deploy --only extensions`) — CI never deploys extensions.
MAIL_COLLECTION=mail
DEFAULT_FROM=observations@orono.k12.mn.us
AUTH_TYPE=UsernamePassword
SMTP_CONNECTION_URI=smtps://observations@orono.k12.mn.us:465
SMTP_PASSWORD=projects/${param:PROJECT_NUMBER}/secrets/firestore-send-email-SMTP_PASSWORD/versions/latest
DATABASE=(default)
DATABASE_REGION=us-central1
OAUTH_PORT=465
OAUTH_SECURE=false
TTL_EXPIRE_TYPE=never
TTL_EXPIRE_VALUE=1
